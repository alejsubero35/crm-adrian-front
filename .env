# --- Multi-tenant host detection ---
# Central host (opcional). Si usas un dominio central único, ponlo aquí.
# VITE_CENTRAL_DOMAIN=

# Lista de hosts centrales permitidos (coma separados). Ej: central.midominio.com,admin.midominio.com
# VITE_CENTRAL_HOSTS=

# Dominio base de tenants. Ej: midominio.com (para tenants tipo acme.midominio.com)
# VITE_TENANT_BASE_DOMAIN=
export const API_URL = import.meta.env.VITE_API_URL || 'http://127-0-0-1.sslip.io'; // Use environment variable

// Default fetch options
export const defaultOptions = {
  headers: {
    'Content-Type': 'application/json',
    'Accept': 'application/json',
    'X-Requested-With': 'XMLHttpRequest'
  }
};